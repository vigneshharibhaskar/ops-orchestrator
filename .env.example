# Copy to .env for local development (never commit .env)

# Postgres DSN — leave blank to use SQLite (local dev / tests)
DATABASE_URL=

# JWT signing secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=supersecret

# Anthropic API key — leave blank to use the deterministic stub planner
ANTHROPIC_API_KEY=

# Environment label (informational)
ENV=development
